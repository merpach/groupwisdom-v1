{
  "name": "groupwisdom-mcp",
  "version": "1.0.0",
  "description": "Claude MCP connector for GroupWisdom — the intelligence layer for groups",
  "type": "module",
  "bin": {
    "groupwisdom-mcp": "dist/mcp.js"
  },
  "files": [
    "dist/mcp.js"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "dev": "tsx src/index.ts",
    "mcp": "node --env-file-if-exists=.env dist/mcp.js",
    "seed": "node dist/seed.js",
    "giftswipe": "cd ../giftswipe && PORT=3001 node_modules/.bin/tsx src/index.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "bcrypt": "^6.0.0",
    "express": "^4.21.0",
    "express-session": "^1.19.0",
    "multer": "^2.1.1",
    "pdf-parse": "^2.4.5",
    "ws": "^8.21.0",
    "zod": "^3.23.0"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.0",
    "@types/express-session": "^1.19.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.18.1",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
